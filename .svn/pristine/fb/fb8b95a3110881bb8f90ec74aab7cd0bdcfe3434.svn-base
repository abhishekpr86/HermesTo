package com.capgemini.onboarding.dto;

import java.util.List;

import com.capgemini.onboarding.model.Bis;
import com.capgemini.onboarding.model.BundleEm;

public class BundleEmDTO {
	
	private List<Bis> bisList ;
	private BundleEm bundleEM;

	public BundleEm getBundleEM() {
		return bundleEM;
	}

	public void setBundleEM(BundleEm bundleEM) {
		this.bundleEM = bundleEM;
	}

	public List<Bis> getBisList() {
		return bisList;
	}

	public void setBisList(List<Bis> bisList) {
		this.bisList = bisList;
	}

	

	
	
	

}
