	@Autowired
	private SessionFactory sessionFactory;
    
	
	public void onboardingReminder() throws Exception{
    	logger.info("onboardingReminder() Method executed at  :: "+ new Date());
		Calendar cal = Calendar.getInstance();
		List<PreOnbEmployee> onboardingLists = new ArrayList<PreOnbEmployee>();
		SimpleDateFormat sdfs = new SimpleDateFormat("yyyy-MM-dd");
		Date dateWithoutTimes = sdfs.parse(sdfs.format(new Date(cal.getTimeInMillis())));
		onboardingLists = preOnbEmpService.getAllPreOnbEmployee();
		for(int employee = 0; employee < onboardingLists.size(); employee++) {
			PreOnbEmployee emp = (PreOnbEmployee) onboardingLists.get(employee);
			
    if(emp.getResourceStatus().equals(OnboardingConstants.statusInitial)) {
    	
    	String RMMailSubj = "[User Management Tool]  Pending onboarding Process for corp id "+emp.getCorpId();
    	Spoc spocRec = this.employeeService.getSpocFromCountry(emp.getCountry().getCountryId());
    	RmPMO rmPMO = preOnbEmpService.getRmPmoDetails();
		String[] recipeintList = {psaMailUtility.prepareMailId(spocRec.getSpocEmail())};
		String[] ccList = {};
		logger.info("RM reminder Mail - start");
		MailSender.send(recipeintList,ccList,MailUtility.RMOnMail(spocRec,emp), RMMailSubj);
		logger.info(RMMailSubj+" sent to "+spocRec.getSpocEmail());
    }
    
    else if(emp.getResourceStatus().equals(OnboardingConstants.statusRMApproved)){
    	
    	String BisPMOMailSubj = "[User Management Tool]  Pending onboarding Process for corp id "+emp.getCorpId();
    	BisPMOMap bisPmo = employeeService.getBISFromPMO(emp.getBis().getBis_id());
    	RmPMO rmPMO = preOnbEmpService.getRmPmoDetails();
    	String[] ccList = {};
    	String[] recipeintList = {psaMailUtility.prepareMailId(bisPmo.getPmo_email())};
    	logger.info("BIS PMO reminder Mail - start");
		MailSender.send(recipeintList,ccList,MailUtility.BISPMOOnMail(bisPmo.getPmo_name(),emp), BisPMOMailSubj);
		logger.info(BisPMOMailSubj+" sent to "+bisPmo.getPmo_email());
      }
		}
		
    }
    
	@Transactional
	public void onboardingReminderwithPSAID() throws Exception{                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
    	logger.info("onboardingReminderwithPSAID() Method executed at  :: "+ new Date());
		Calendar cal = Calendar.getInstance();
		List<String> listOfIds=new ArrayList<String>(); 
		List<String> listOfIdFirstName=new ArrayList<String>();
		List<String> listOfIdLastName=new ArrayList<String>();
		List<String> listOfIdPrimayprogram=new ArrayList<String>();
		List<String> listOfSubmitDates=new ArrayList<String>();   
		List<String> listOfCorpIds=new ArrayList<String>(); 
		List<String> listOfCorpIdFirstName=new ArrayList<String>(); 
		List<String> listOfCorpIdLastName=new ArrayList<String>(); 
		List<String> listOfCorpIdPrimaryprogram=new ArrayList<String>(); 
		List<String> listOfBisPmoSubmitDate=new ArrayList<String>();
        String RMPMOMailSubj = "[User Management Tool]  Pending onboarding Process ";                                                                        
		RmPMO rmPMO = preOnbEmpService.getRmPmoDetails();
		String[] recipient ={psaMailUtility.prepareSheduleMailId(this.preOnbEmpService.getDLListbyRole("IndiaVLAN").getEmail())};
	    String[] recipeintList = {psaMailUtility.prepareMailId(rmPMO.getEmail())};
		//String[] ccList = {psaMailUtility.prepareSheduleMailId(this.preOnbEmpService.getDLListbyRole("ASLSupport").getEmail())};
	    String[] ccList ={psaMailUtility.prepareSheduleMailId(this.preOnbEmpService.getDLListbyRole("IndiaVLAN").getEmail())};
		//String name =this.preOnbEmpService.getDLListbyRole("ASLSupport").getName();
		String name = "Team";//mehens
		String queryString = null;
			Session session = this.sessionFactory.getCurrentSession();
			queryString = OnBoardingSQLQueries.bisPmoSubmit;
			List<Employee> listEmployees = new ArrayList<>();
			TypedQuery<Employee> query = session.createSQLQuery(queryString);
			listEmployees=query.getResultList();
			Iterator itr = listEmployees.iterator();
			Date bispmoSubmitDT=null;
			Date rmpmoSubmitDT=null;
			while (itr.hasNext()) {
				PreOnbEmployee emp = new PreOnbEmployee();
				PrimaryProgram primary = new PrimaryProgram();
				Object[] obj = (Object[]) itr.next();
				if (String.valueOf(obj[1]) != null) {
					emp.setCorpId(String.valueOf(obj[1]));
				}
				
				if (String.valueOf(obj[2]) != null && !String.valueOf(obj[2]).equalsIgnoreCase("null")
						&& !String.valueOf(obj[2]).equalsIgnoreCase("")) {
					 
					emp.setBISPMOSubmitDT((Date) obj[2]);
				}
				if (String.valueOf(obj[3]) != null) {
					emp.setResourceStatus(String.valueOf(obj[3]));
				}
				if (String.valueOf(obj[4]) != null && !String.valueOf(obj[4]).equalsIgnoreCase("null")
						&& !String.valueOf(obj[4]).equalsIgnoreCase("")) {
					 
					emp.setRMPMOSubmitDT((Date) obj[4]);
				}
				if (String.valueOf(obj[5])!=null ) {
					 
					emp.setFirstName(String.valueOf(obj[5]));
					
					
				}
				if (String.valueOf(obj[6])!=null ) {
					 
					emp.setLastName(String.valueOf(obj[6]));
					
					
				}
				if (String.valueOf(obj[7])!=null ) {
					 
					primary.setPrimaryProgramName(String.valueOf(obj[7]));
					emp.setPrimaryprogram(primary);
					
					
					
				}
				 
				
				
				/*if (String.valueOf(obj[7]) != null && !String.valueOf(obj[4]).equalsIgnoreCase("null")
						&& !String.valueOf(obj[4]).equalsIgnoreCase("")) {
					 
					//emp.getPrimaryprogram().setPrimaryProgramId(primaryProgramId);
					
					
				}*/
				if(emp.getResourceStatus().equals(OnboardingConstants.statusBISPMOSubmit)) {
			
					Date input = emp.getBISPMOSubmitDT();
					LocalDate date = input.toInstant().atZone(ZoneId.systemDefault()).toLocalDate();
					int days=4;
					LocalDate dates=addDaysSkippingWeekends(date, days);
					Date datess = Date.from(dates.atStartOfDay(ZoneId.systemDefault()).toInstant());
			        LocalDate currentDate = LocalDate.now(); 
			        LocalDate datesSubtract=subtractDaysSkippingWeekends(currentDate, days);
			        LocalDate preonboardDate = emp.getBISPMOSubmitDT().toInstant().atZone(ZoneId.systemDefault()).toLocalDate();
					if((dates!=null ) &&( (emp.getBISPMOSubmitDT().before(datess)) && (!(emp.getBISPMOSubmitDT().equals(datess))) &&(!(currentDate.equals(preonboardDate)))))
					{
						if(preonboardDate.isBefore(datesSubtract)) {
							listOfIds.add(emp.getCorpId());
							listOfIdFirstName.add(emp.getFirstName());
							listOfIdLastName.add(emp.getLastName());
							 if(emp.getPrimaryprogram()!=null) {
								 listOfIdPrimayprogram.add(emp.getPrimaryprogram().getPrimaryProgramName());
							 }
					        listOfSubmitDates.add(emp.getBISPMOSubmitDT().toString());
					        
					}
					
				}
				}
				else if(emp.getResourceStatus().equals(OnboardingConstants.statusVMRequested)) {
							Date submitDate =emp.getRMPMOSubmitDT();
							LocalDate localDate = submitDate.toInstant().atZone(ZoneId.systemDefault()).toLocalDate();
							int addDays=4;
							LocalDate additionOfDates =addDaysSkippingWeekends(localDate, addDays);
							Date conversionDates = Date.from(additionOfDates.atStartOfDay(ZoneId.systemDefault()).toInstant());
						    LocalDate currentDates = LocalDate.now();  
					        LocalDate datesSubtracts=subtractDaysSkippingWeekends(currentDates, addDays);
					      
					        LocalDate preonboardDates = emp.getRMPMOSubmitDT().toInstant().atZone(ZoneId.systemDefault()).toLocalDate();
							if((additionOfDates!=null ) &&( (emp.getRMPMOSubmitDT().before(conversionDates)) && (!(emp.getRMPMOSubmitDT().equals(conversionDates))) &&(!(currentDates.equals(preonboardDates)))))
							{
								if(preonboardDates.isBefore(datesSubtracts)) {
									
									listOfCorpIds.add(emp.getCorpId());
									listOfCorpIdFirstName.add(emp.getFirstName());
									listOfCorpIdLastName.add(emp.getLastName());
									 if(emp.getPrimaryprogram()!=null) {
										 listOfCorpIdPrimaryprogram.add(emp.getPrimaryprogram().getPrimaryProgramName());
									 }
							       
							   listOfBisPmoSubmitDate.add(emp.getRMPMOSubmitDT().toString());
							}
								//listOfCorpIds.add(emp.getPrimaryprogram().getPrimaryProgramName());
								
							}
							}
				}
						
			
		if(listOfIds!=null &&(!listOfIds.isEmpty())) {
			//MailSender.send(recipient,ccList,MailUtility.RMPMOOnMails(name,listOfIdFirstName,listOfIdFirstName,listOfIdLastName,listOfIdPrimayprogram,listOfSubmitDates), RMPMOMailSubj);
			MailSender.send(recipeintList,ccList,MailUtility.RMPMOOnMails(name,listOfIdFirstName,listOfIdFirstName,listOfIdLastName,listOfIdPrimayprogram,listOfSubmitDates), RMPMOMailSubj);
			logger.info(RMPMOMailSubj+" sent to "+rmPMO.getEmail());
		}
		else if(listOfCorpIds!=null &&(!listOfCorpIds.isEmpty())) {
			//MailSender.send(recipient,ccList,MailUtility.RMPMOVMMails(name,listOfCorpIds,listOfCorpIdFirstName,listOfCorpIdLastName,listOfCorpIdPrimaryprogram,listOfBisPmoSubmitDate), RMPMOMailSubj);
			MailSender.send(recipeintList,ccList,MailUtility.RMPMOVMMails(name,listOfCorpIds,listOfCorpIdFirstName,listOfCorpIdLastName,listOfCorpIdPrimaryprogram,listOfBisPmoSubmitDate), RMPMOMailSubj);
			logger.info(RMPMOMailSubj+" sent to "+rmPMO.getEmail());
		}
			}
		


	private static LocalDate addDaysSkippingWeekends(LocalDate date, int days) {
		LocalDate result = date;
		int addedDays = 0;
		while (addedDays < days) {
		result = result.plusDays(1);
		if (!(result.getDayOfWeek() == DayOfWeek.SATURDAY || result.getDayOfWeek() == DayOfWeek.SUNDAY)) {
		++addedDays;
		}
		}
		return result;
		}
	
	private static LocalDate subtractDaysSkippingWeekends(LocalDate date, int days) {
		LocalDate result = date;
		int addedDays = 0;
		while (addedDays < days) {
		result = result.minusDays(1);
		if (!(result.getDayOfWeek() == DayOfWeek.SATURDAY || result.getDayOfWeek() == DayOfWeek.SUNDAY)) {
		++addedDays;
		}
		}
		return result;
		}
		
	
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 
