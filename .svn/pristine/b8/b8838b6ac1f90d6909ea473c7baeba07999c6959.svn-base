package com.capgemini.onboarding.service;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import com.capgemini.onboarding.dao.UsersDao;
import com.capgemini.onboarding.model.Role;
import com.capgemini.onboarding.model.UserRoles;
import com.capgemini.onboarding.model.Users;

@Service
public class UsersServiceImpl implements UsersService{

		@Autowired
		private UsersDao usersDao;
		
		
@Override
@Transactional
	public void addUsers(Users users) {
		this.usersDao.addUsers(users);
			
		}

@Override
@Transactional
  public Users getUsersById(String id) {
		return this.usersDao.getUsersById(id);
		}

@Override
@Transactional
public List<UserRoles> searchhUsers(UserRoles users) {
	return this.usersDao.searchhUsers(users);
}

@Override
@Transactional
public void updateUsers(Users users) {
	this.usersDao.updateUsers(users);
	
}

@Override
@Transactional
public boolean checkUserNameExists(String userName, String userNameHidden) {
	return this.usersDao.checkUserNameExists(userName , userNameHidden);
}

@Override
@Transactional
public void deleteUserRole(UserRoles users) {
	
	this.usersDao.deleteUserRole(users);
}

@Override
@Transactional
public List<Role> addRoleList(String userName) {
	return this.usersDao.addRoleList(userName);
}

@Override
@Transactional
public void addUserRole(UserRoles userRole) {
	this.usersDao.addUserRole(userRole);
	
}
		
		

}
