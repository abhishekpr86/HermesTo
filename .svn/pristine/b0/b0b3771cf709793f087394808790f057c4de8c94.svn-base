package com.capgemini.onboarding.model;

public class HeadCountReport {
	
	private long firstMonthCount;
	private long secondMonthCount;
	private long thirdMonthCount;
	private long forthMonthCount;
	private long fifthMonthCount;
	private long sixthMonthCount;
	
	
	public long getFirstMonthCount() {
		return firstMonthCount;
	}
	public void setFirstMonthCount(long firstMonthCount) {
		this.firstMonthCount = firstMonthCount;
	}
	public long getSecondMonthCount() {
		return secondMonthCount;
	}
	public void setSecondMonthCount(long secondMonthCount) {
		this.secondMonthCount = secondMonthCount;
	}
	public long getThirdMonthCount() {
		return thirdMonthCount;
	}
	public void setThirdMonthCount(long thirdMonthCount) {
		this.thirdMonthCount = thirdMonthCount;
	}
	public long getForthMonthCount() {
		return forthMonthCount;
	}
	public void setForthMonthCount(long forthMonthCount) {
		this.forthMonthCount = forthMonthCount;
	}
	public long getFifthMonthCount() {
		return fifthMonthCount;
	}
	public void setFifthMonthCount(long fifthMonthCount) {
		this.fifthMonthCount = fifthMonthCount;
	}
	public long getSixthMonthCount() {
		return sixthMonthCount;
	}
	public void setSixthMonthCount(long sixthMonthCount) {
		this.sixthMonthCount = sixthMonthCount;
	}
	
	
	

}
