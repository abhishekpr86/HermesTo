public class OnboardingRevocationEmails {
	
	private Logger logger = Logger.getLogger(OnboardingRevocationEmails.class);
	
	@Autowired(required = true)
	private EmployeeService employeeService;
	
	@Autowired(required = true)
	private PreOnbEmployeeService preOnbEmpService;
	
    @Autowired(required = true)
